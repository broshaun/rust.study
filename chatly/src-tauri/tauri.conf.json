{
  "$schema": "https://schema.tauri.app/config/2",
  
  "productName": "Chatly",
  "version": "0.1.0",
  "identifier": "com.chatly.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://192.168.0.104:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
    
  },
  "app": {
    "windows": [
      {
        "title": "Chatly",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https: http: data: blob:; connect-src 'self' https: http:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
