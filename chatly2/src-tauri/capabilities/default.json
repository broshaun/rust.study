{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "http:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://192.168.2.2:5015/*"
        },
        {
          "url": "http://103.186.108.161:5015/*"
        }
      ]
    },
    "store:default"
  ]
}