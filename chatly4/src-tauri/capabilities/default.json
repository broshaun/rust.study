{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://192.168.2.2:5015/*"
        },
        {
          "url": "http://103.186.108.161:5015/*"
        }
      ]
    },
    "fs:allow-exists",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-create",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-copy-file",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-fstat",
    "fs:allow-lstat",
    "fs:allow-stat",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "**"
        }
      ]
    }
  ]
}