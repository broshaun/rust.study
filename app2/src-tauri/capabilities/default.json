{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "http:allow-fetch",
    "core:webview:allow-create-webview-window",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://localhost:5015/*"
        }
      ]
    },
    "log:default"
  ]
}